{
  "name": "ui-packages",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "jest --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:dev": "changeset version --snapshot dev && pnpm build && changeset publish --tag dev --no-git-tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@swc/core": "^1.7.0",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.7.0"
  }
}
